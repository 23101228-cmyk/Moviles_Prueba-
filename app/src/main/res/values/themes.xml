<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.P2P" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/binance_yellow</item>
        <item name="colorPrimaryVariant">@color/binance_yellow_dark</item>
        <item name="colorOnPrimary">@color/binance_bg</item>
        <item name="colorSecondary">@color/binance_yellow</item>
        <item name="colorSecondaryVariant">@color/binance_yellow_dark</item>
        <item name="colorOnSecondary">@color/binance_bg</item>
        <item name="colorSurface">@color/binance_surface</item>
        <item name="colorOnSurface">@color/binance_text_primary</item>
        <item name="android:colorAccent">@color/binance_yellow</item>
        <item name="android:navigationBarColor">@color/binance_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/binance_bg</item>
        <item name="editTextStyle">@style/Widget.P2P.EditText</item>
        <item name="textInputStyle">@style/Widget.P2P.TextInputLayout</item>
    </style>

    <style name="Widget.P2P.EditText" parent="@android:style/Widget.EditText">
        <item name="android:textColor">@color/binance_text_primary</item>
        <item name="android:textColorHint">@color/binance_text_secondary</item>
        <item name="android:backgroundTint">@color/binance_border</item>
    </style>

    <style name="Widget.P2P.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/binance_surface</item>
        <item name="boxStrokeColor">@color/binance_border</item>
        <item name="hintTextColor">@color/binance_text_secondary</item>
        <item name="android:textColorHint">@color/binance_text_secondary</item>
    </style>

    <style name="Theme.P2P.NoActionBar" parent="Theme.P2P" />

    <!-- Splash Screen API Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/binance_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_p2p_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.P2P</item>
    </style>
</resources>
