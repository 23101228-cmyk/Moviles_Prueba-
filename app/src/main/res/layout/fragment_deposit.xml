<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══ TOP BAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <ImageButton
                android:id="@+id/btnViewMovements"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_market"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#1A1A1A"
                android:contentDescription="Ver movimientos" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/layoutLang"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/bg_lang_pill">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐 ES"
                    android:textSize="12sp"
                    android:textColor="#1A1A1A" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    android:contentDescription="Idioma" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ LOGO ══ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_p2p_logo"
                android:contentDescription="Logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P2P"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIVISAS"
                    android:textSize="9sp"
                    android:letterSpacing="0.12"
                    android:textColor="#1A1A1A" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ TITLE ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:text="Depositar saldo"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="Recarga tu wallet virtual"
            android:textSize="13sp"
            android:textColor="#888888" />

        <!-- ══ MONEDA SECTION ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="Moneda"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <!-- Currency selector chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="10dp"
            android:weightSum="3">

            <!-- PEN chip -->
            <LinearLayout
                android:id="@+id/chipPen"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_chip_selected"
                android:padding="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_flag_pen"
                    android:contentDescription="PEN" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PEN"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soles"
                        android:textSize="10sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </LinearLayout>

            <!-- USD chip -->
            <LinearLayout
                android:id="@+id/chipUsd"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_chip_unselected"
                android:padding="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_flag_usd"
                    android:contentDescription="USD" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USD"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dólares"
                        android:textSize="10sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </LinearLayout>

            <!-- EUR chip -->
            <LinearLayout
                android:id="@+id/chipEur"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_chip_unselected"
                android:padding="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_wallet"
                    android:contentDescription="EUR" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EUR"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Euros"
                        android:textSize="10sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ══ MONTO SECTION ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="Monto"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <!-- Amount input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMonto"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusTopStart="10dp"
            app:boxStrokeColor="#E0E0E0"
            app:prefixText="S/"
            app:prefixTextColor="#1A1A1A">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMonto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ingresa el monto"
                android:inputType="numberDecimal"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Min/Max hint -->
        <TextView
            android:id="@+id/tvMontoHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="4dp"
            android:text="Monto mínimo: S/ 10.00 · Máximo: S/ 30,000.00"
            android:textSize="11sp"
            android:textColor="#AAAAAA" />

        <!-- ══ INFO BANNER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_info_banner"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="top">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_wallet"
                app:tint="#F5A623"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="1dp"
                android:contentDescription="Info" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recarga simulada para fines del proyecto."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Esta operación no implica dinero real."
                    android:textSize="12sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ RESUMEN SECTION ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="Resumen"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_resumen_card"
            android:padding="16dp">

            <!-- Moneda row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Moneda"
                    android:textSize="14sp"
                    android:textColor="#444444" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_flag_pen"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="PEN" />

                    <TextView
                        android:id="@+id/tvResumenMoneda"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PEN (Soles)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Monto a recargar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Monto a recargar"
                    android:textSize="14sp"
                    android:textColor="#444444" />

                <TextView
                    android:id="@+id/tvResumenMonto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 0.00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Saldo disponible después row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Saldo disponible después ⓘ"
                    android:textSize="14sp"
                    android:textColor="#444444" />

                <TextView
                    android:id="@+id/tvResumenSaldoFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/ 0.00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

        </LinearLayout>

        <!-- ══ CONFIRMAR BUTTON ══ -->
        <Button
            android:id="@+id/btnConfirmar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="28dp"
            android:text="Confirmar recarga"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F5A623"
            app:cornerRadius="12dp" />

        <!-- Cancelar link -->
        <TextView
            android:id="@+id/tvCancelar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:text="Cancelar"
            android:textSize="14sp"
            android:textColor="#888888" />

    </LinearLayout>
</ScrollView>
