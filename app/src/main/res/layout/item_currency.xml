<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/imgCurrencyFlag"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvCurrencyCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="PEN"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/binance_text_primary"
        app:layout_constraintStart_toEndOf="@id/imgCurrencyFlag"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCurrencyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sol peruano"
        android:textSize="13sp"
        android:textColor="@color/binance_text_secondary"
        app:layout_constraintStart_toStartOf="@id/tvCurrencyCode"
        app:layout_constraintTop_toBottomOf="@id/tvCurrencyCode" />

    <TextView
        android:id="@+id/tvCurrencyAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S/ 0.00"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/binance_text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCurrencyAmountAlt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S/ 0.00"
        android:textSize="12sp"
        android:textColor="@color/binance_text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCurrencyAmount" />

</androidx.constraintlayout.widget.ConstraintLayout>
