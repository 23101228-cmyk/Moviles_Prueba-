<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F7">

    <!-- ══ TOP BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Movimientos"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_filter"
            android:contentDescription="Filtrar" />
    </LinearLayout>

    <!-- ══ CURRENCY TABS (Todos / PEN / USD / EUR) ══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/layoutCurrencyTabs"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tab_group"
            android:padding="3dp">

            <TextView
                android:id="@+id/tabTodos"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Todos"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tabPen"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="PEN"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tabUsd"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="USD"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tabEur"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="EUR"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:textColor="#888888" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ══ TYPE FILTER CHIPS (Todos / Recargas / Retenciones / Liberaciones / Pagos) ══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/layoutTypeChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Todos"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_type_chip_selected" />

            <TextView
                android:id="@+id/chipRecargas"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Recargas"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_type_chip_unselected" />

            <TextView
                android:id="@+id/chipRetenciones"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Retenciones"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_type_chip_unselected" />

            <TextView
                android:id="@+id/chipLiberaciones"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Liberaciones"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_type_chip_unselected" />

            <TextView
                android:id="@+id/chipPagos"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Pagos"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center"
                android:background="@drawable/bg_type_chip_unselected" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- ══ MOVEMENTS LIST ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMovimientos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F7F7F7"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

</LinearLayout>
