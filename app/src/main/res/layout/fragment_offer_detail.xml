<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/binance_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Volver"
            android:textColor="@color/binance_yellow"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalle de oferta"
            android:textColor="@color/binance_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOfferCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="OFR-1001"
            android:textColor="@color/binance_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carlos_P2P"
                android:textColor="@color/binance_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUserStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="250 operaciones | 99% reputacion"
                android:textColor="@color/binance_text_secondary" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="4">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Estado" android:textColor="@color/binance_text_secondary" />
            <TextView android:id="@+id/tvStatus" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="ACTIVA" android:textColor="@color/binance_text_primary" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:text="Operacion" android:textColor="@color/binance_text_secondary" />
            <TextView android:id="@+id/tvOperation" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:text="VENTA" android:textColor="@color/binance_text_primary" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:text="Par" android:textColor="@color/binance_text_secondary" />
            <TextView android:id="@+id/tvPair" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:text="USD / PEN" android:textColor="@color/binance_text_primary" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:text="Tasa" android:textColor="@color/binance_text_secondary" />
            <TextView android:id="@+id/tvRate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:text="S/ 3.7500" android:textColor="@color/binance_yellow" android:textStyle="bold" />
        </GridLayout>

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Monto ofertado: $ 1,200.00 USD"
            android:textColor="@color/binance_text_primary" />

        <TextView
            android:id="@+id/tvMinimum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Minimo aceptado: $ 100.00 USD"
            android:textColor="@color/binance_text_secondary" />

        <TextView
            android:id="@+id/tvTimeLimit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="15 minutos"
            android:textColor="@color/binance_text_secondary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="Monto de operacion"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:textColorHint="@color/binance_text_secondary"
                android:textColor="@color/binance_text_primary"
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:hint="Ej. 100" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Metodo de pago"
            android:textColor="@color/binance_text_primary"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioPaymentMethods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvPaymentInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_info_banner"
            android:padding="12dp"
            android:text="Los datos de pago se mostraran despues de iniciar."
            android:textColor="@color/binance_text_primary" />

        <TextView
            android:id="@+id/tvTotalLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Total a pagar"
            android:textColor="@color/binance_text_secondary" />

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="S/ 0.00 PEN"
            android:textColor="@color/binance_yellow"
            android:textSize="22sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartTransaction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Iniciar transaccion"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelBeforeStart"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Cancelar y volver al mercado"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
