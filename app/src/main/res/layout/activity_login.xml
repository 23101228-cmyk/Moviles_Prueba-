<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/binance_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_p2p_logo"
                android:contentDescription="Logo P2P" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="9dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P2P"
                    android:textStyle="bold"
                    android:textSize="27sp"
                    android:textColor="@color/binance_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIVISAS"
                    android:textSize="15sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/binance_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:text="Iniciar sesión"
            android:textSize="39sp"
            android:textStyle="bold"
            android:textColor="@color/binance_text_primary" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="9dp"
            android:text="Accede a tu cuenta y comienza a"
            android:textSize="20sp"
            android:textColor="@color/binance_text_secondary"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvSubtitleLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="comprar y vender divisas."
            android:textSize="20sp"
            android:textColor="@color/binance_yellow"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- ── Correo electrónico ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_gravity="center_horizontal"
            android:text="Correo electrónico"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="@color/binance_text_primary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCorreo"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            app:boxCornerRadiusBottomEnd="15dp"
            app:boxCornerRadiusBottomStart="15dp"
            app:boxCornerRadiusTopEnd="15dp"
            app:boxCornerRadiusTopStart="15dp"
            app:boxStrokeColor="@color/binance_border"
            app:boxStrokeWidthFocused="2dp"
            app:startIconDrawable="@drawable/ic_email"
            app:startIconTint="#BDBDBD">

            <com.google.android.material.textfield.TextInputEditText
                android:textColorHint="@color/binance_text_secondary"
                android:textColor="@color/binance_text_primary"
                android:id="@+id/etCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ingresa tu correo electrónico"
                android:inputType="textEmailAddress"
                android:textSize="21sp"
                android:padding="20dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Contraseña ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal"
            android:text="Contraseña"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="@color/binance_text_primary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContrasena"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            app:boxCornerRadiusBottomEnd="15dp"
            app:boxCornerRadiusBottomStart="15dp"
            app:boxCornerRadiusTopEnd="15dp"
            app:boxCornerRadiusTopStart="15dp"
            app:boxStrokeColor="@color/binance_border"
            app:boxStrokeWidthFocused="2dp"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="#BDBDBD"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:textColorHint="@color/binance_text_secondary"
                android:textColor="@color/binance_text_primary"
                android:id="@+id/etContrasena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ingresa tu contraseña"
                android:inputType="textPassword"
                android:textSize="21sp"
                android:padding="20dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── ¿Olvidaste tu contraseña? ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="18dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvOlvideContrasena"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Olvidaste tu contraseña?"
                android:textSize="20sp"
                android:textColor="@color/binance_yellow"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Botón Ingresar ── -->
        <Button
            android:id="@+id/btnIngresar"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginTop="42dp"
            android:text="Ingresar"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/binance_text_primary"
            android:backgroundTint="@color/binance_yellow"
            app:cornerRadius="18dp" />

        <!-- ── ¿No tienes cuenta? Regístrate ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? "
                android:textSize="20sp"
                android:textColor="@color/binance_text_secondary" />

            <TextView
                android:id="@+id/tvRegistrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Regístrate"
                android:textSize="20sp"
                android:textColor="@color/binance_yellow"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
