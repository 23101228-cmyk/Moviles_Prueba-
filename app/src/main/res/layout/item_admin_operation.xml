<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAdminOperationId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OPE-0000"
                android:textColor="@color/binance_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdminOperationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EN_DISPUTA"
                android:textColor="@color/binance_yellow"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAdminOperationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="VENTA USD/PEN - 100.00 USD"
            android:textColor="@color/binance_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAdminOperationDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Metodo: Yape | Total: S/ 375.00"
            android:textColor="@color/binance_text_secondary"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResolveDispute"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="Resolver disputa"
            android:textColor="@color/binance_text_primary"
            app:backgroundTint="@color/binance_yellow"
            app:cornerRadius="10dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
